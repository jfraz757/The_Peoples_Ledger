# Copy this file to .env and fill in your actual keys.
# Never commit .env to GitHub -- it is listed in .gitignore.

# Get your SerpApi key at https://serpapi.com (100 free searches/month)
SERPAPI_KEY=your_serpapi_key_here

# Get your Anthropic key at https://console.anthropic.com (~$0.003/page scanned)
ANTHROPIC_API_KEY=your_anthropic_key_here
